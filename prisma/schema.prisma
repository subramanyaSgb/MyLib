generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// Supported stores. Hardcoded enum-ish via string since SQLite lacks enum support.
model Store {
  id       String    @id // "steam" | "epic" | "gog" | "stove" | "play"
  name     String
  accounts Account[]
}

/// A linked user account on a store. One user may have MANY accounts per store.
model Account {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  label       String   // user-chosen nickname, e.g. "Main", "Alt"
  externalId  String?  // SteamID64, Epic account id, GOG user id, etc.
  displayName String?  // Profile name from store
  avatarUrl   String?
  /// Encrypted JSON blob: { apiKey, cookie, token, refreshToken, ... } — per-store shape
  credsEnc    String
  createdAt   DateTime @default(now())
  lastSyncAt  DateTime?
  lastSyncOk  Boolean  @default(false)
  lastError   String?

  owned OwnedCopy[]
  wishlist WishlistItem[]

  @@unique([storeId, externalId])
  @@index([storeId])
}

/// Canonical game. Deduplicated across stores by normalized title + optional metadata.
model Game {
  id         String   @id @default(cuid())
  title      String
  normTitle  String   // lowercased, stripped for dedupe
  coverUrl   String?
  releaseYear Int?
  /// Developer studio (best-of fields across stores).
  dev        String?
  /// Primary genre label.
  genre      String?
  /// JSON-encoded array of tag/category strings.
  tagsJson   String?
  /// Item kind: "game" | "dlc" | "pack" | "addon" | "music" | "demo" | other.
  /// Default null (unknown). Library grid hides non-game by default.
  kind       String?
  /// Available on NVIDIA GeForce Now cloud streaming.
  cloudGfn   Boolean  @default(false)
  /// Available on Xbox Cloud Gaming (PC Game Pass).
  cloudXcloud Boolean @default(false)
  /// Last time we cross-referenced this game against cloud catalogs.
  lastCloudCheckAt DateTime?
  /// Play status set by user. Values: "backlog" | "playing" | "done" | "dropped" | null.
  playState  String?
  isFavorite Boolean  @default(false)
  isHidden   Boolean  @default(false)
  /// When set, treats this Game as "merged" — only the OwnedCopy belonging to
  /// this Account is shown in the main library; other copies are kept for
  /// stats but suppressed from the grid.
  mergedPrimaryAccountId String?
  createdAt  DateTime @default(now())

  copies      GameOnStore[]
  wishlistItems WishlistItem[]
  tags        GameTag[]

  @@index([normTitle])
  @@index([isFavorite])
  @@index([isHidden])
  @@index([playState])
}

/// A game as it exists on a specific store (has store-specific IDs/art).
model GameOnStore {
  id           String @id @default(cuid())
  gameId       String
  game         Game   @relation(fields: [gameId], references: [id])
  storeId      String // "steam" etc — no FK to keep inserts cheap
  storeGameId  String // appid for Steam, gog product id, etc.
  storeTitle   String
  coverUrl     String?
  storeUrl     String?

  owned OwnedCopy[]

  @@unique([storeId, storeGameId])
  @@index([gameId])
}

/// Which account owns which GameOnStore + usage metadata.
model OwnedCopy {
  id             String   @id @default(cuid())
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  gameOnStoreId  String
  gameOnStore    GameOnStore @relation(fields: [gameOnStoreId], references: [id])
  playtimeMin    Int      @default(0)
  lastPlayedAt   DateTime?
  purchasedAt    DateTime?
  achievementsUnlocked Int?
  achievementsTotal    Int?
  firstSeenAt    DateTime @default(now())
  lastSeenAt     DateTime @default(now())

  @@unique([accountId, gameOnStoreId])
  @@index([accountId])
  @@index([gameOnStoreId])
}

/// A game on a wishlist (NOT necessarily owned). Per-account so we can tell
/// which account wants what; deduped to canonical Game when title matches.
model WishlistItem {
  id           String   @id @default(cuid())
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  storeId      String   // "steam" | "gog"
  storeGameId  String   // appid for Steam, productId for GOG
  title        String
  coverUrl     String?
  storeUrl     String?
  /// Cents in the store's user-currency (e.g. 1999 = ₹19.99 if Steam region IN).
  fullPriceCents    Int?
  currentPriceCents Int?
  discountPct       Int?     // 0-100
  currency          String?  // ISO-ish, "USD", "INR" etc. — best-effort.
  isOnSale          Boolean  @default(false)
  /// User-set target trigger price.
  targetPriceCents  Int?
  /// Optional canonical Game link.
  gameId       String?
  game         Game?    @relation(fields: [gameId], references: [id])
  addedAt      DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  snapshots    PriceSnapshot[]
  alerts       PriceAlert[]
  externalDeal ExternalDeal?

  @@unique([accountId, storeGameId])
  @@index([accountId])
  @@index([gameId])
  @@index([isOnSale])
}

/// Price snapshot for a wishlist item — captured each sync so we can detect
/// "new all-time low" and render history charts.
model PriceSnapshot {
  id              String   @id @default(cuid())
  wishlistItemId  String
  wishlistItem    WishlistItem @relation(fields: [wishlistItemId], references: [id], onDelete: Cascade)
  priceCents      Int
  currency        String?
  discountPct     Int?
  capturedAt      DateTime @default(now())

  @@index([wishlistItemId, capturedAt])
}

/// Alert raised when wishlist price crosses target or hits all-time low.
model PriceAlert {
  id              String   @id @default(cuid())
  wishlistItemId  String
  wishlistItem    WishlistItem @relation(fields: [wishlistItemId], references: [id], onDelete: Cascade)
  /// "target_hit" — currentPriceCents <= targetPriceCents
  /// "new_low"   — currentPriceCents below every prior snapshot
  kind            String
  priceCents      Int
  /// Target at moment of firing (null for new_low).
  targetCents     Int?
  /// Previous low at firing time (for context in UI).
  prevLowCents    Int?
  currency        String?
  firedAt         DateTime @default(now())
  dismissedAt     DateTime?

  @@index([wishlistItemId])
  @@index([dismissedAt])
  @@index([firedAt])
}

/// Cross-store deal for a wishlist item, sourced from IsThereAnyDeal. Tracks
/// the current cheapest offer across all supported stores plus the all-time
/// low seen by ITAD (for "can still go lower" signals).
model ExternalDeal {
  id              String   @id @default(cuid())
  wishlistItemId  String   @unique
  wishlistItem    WishlistItem @relation(fields: [wishlistItemId], references: [id], onDelete: Cascade)
  /// Shop identifier as returned by ITAD (e.g. "steam", "gog", "epic", "humblestore").
  bestShop        String
  bestShopName    String
  bestPriceCents  Int
  bestUrl         String?
  /// Historical low seen by ITAD across all shops.
  historicalLowCents Int?
  historicalLowShop  String?
  currency        String?
  fetchedAt       DateTime @default(now())

  @@index([wishlistItemId])
}

/// Free-to-claim offer from Epic / GOG / other stores. Refreshed by a sync job.
model FreeOffer {
  id          String   @id @default(cuid())
  storeId     String   // "epic" | "gog" | "steam" | ...
  /// Store-native product id (Epic offer id, GOG product id, Steam appid).
  externalId  String
  title       String
  coverUrl    String?
  url         String
  /// "free_keep" (claim permanently), "free_play" (free weekend / trial),
  /// "giveaway" (time-bound giveaway), "perma_free" (always free).
  offerType   String
  startsAt    DateTime?
  endsAt      DateTime?
  /// Price before offer (cents). Null when unknown.
  originalCents Int?
  currency    String?
  fetchedAt   DateTime @default(now())
  dismissedAt DateTime?

  @@unique([storeId, externalId])
  @@index([endsAt])
  @@index([offerType])
  @@index([dismissedAt])
}

/// User-created label applied to games ("backlog pile", "coop with Priya", etc.).
model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  /// Optional accent color (hex, e.g. "#7c5cff").
  color     String?
  createdAt DateTime @default(now())
  games     GameTag[]
}

/// Many-to-many join.
model GameTag {
  gameId String
  tagId  String
  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([gameId, tagId])
  @@index([tagId])
}
