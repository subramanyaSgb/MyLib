DATABASE_URL="file:./prisma/dev.db"

# 32-byte base64. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDS_KEY=""

# Steam Web API key — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=""

# Background auto-sync threshold in hours. 0 = disabled.
AUTOSYNC_HOURS="6"

# Wishlist + price region override. ISO country + currency code (defaults: IN/INR).
STORE_REGION="IN"
STORE_CURRENCY="INR"

# GeForce Now region (ISO country code: IN/US/GB/EU/DE/JP).
GFN_REGION="IN"

# IsThereAnyDeal v2 API key — free at https://isthereanydeal.com/apps/my/
# Enables cross-store cheapest-price discovery on wishlist items.
ITAD_API_KEY=""
